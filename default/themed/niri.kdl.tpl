layout {
    border {
        active-color "{{ accent }}"
        inactive-color "{{ color8 }}"
        urgent-color "{{ color1 }}"
    }

    tab-indicator {
        active-color "{{ accent }}"
        inactive-color "{{ color8 }}"
        urgent-color "{{ color1 }}"
    }

    insert-hint {
        color "{{ accent }}80"
    }
}

recent-windows {
    highlight {
        active-color "{{ accent }}"
        urgent-color "{{ color1 }}"
    }
}