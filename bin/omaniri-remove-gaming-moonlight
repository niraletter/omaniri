#!/bin/bash

# omaniri:summary=Remove Moonlight and its configs and caches.
# omaniri:requires-sudo=true

set -e

omaniri-pkg-drop moonlight-qt

rm -rf \
  "$HOME/.config/Moonlight Game Streaming Project" \
  "$HOME/.cache/Moonlight Game Streaming Project"

echo ""
echo "Moonlight and its data have been removed."
