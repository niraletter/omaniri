#!/bin/bash

# omaniri:summary=Reinstall all default omaniri packages from the stable channel
# omaniri:requires-sudo=true

set -e

# Reinstall all default omaniri packages from the stable channel and downgrade any packages that are too new.

# Set the package repository to the stable mirrors
omaniri-refresh-pacman

# Downgrade any packages to the stable setup
sudo pacman -Suu --noconfirm

# Ensure all packages are installed
mapfile -t packages < <(grep -v '^#' "$OMANIRI_PATH/install/omaniri-base.packages" | grep -v '^$')
sudo pacman -Syu --noconfirm --needed "${packages[@]}"
