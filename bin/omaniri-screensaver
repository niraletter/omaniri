#!/bin/bash

# omaniri:summary=Run the omaniri screensaver using random effects from TTE.

screensaver_in_focus() {
  niri msg -j focused-window 2>/dev/null | jq -e '
    if .Ok then (.Ok | if type == "object" then . else .[0] end) | .app_id == "org.omaniri.screensaver"
    else false end
  ' >/dev/null 2>&1
}

exit_screensaver() {
  pkill -x tte 2>/dev/null
  pkill -f org.omaniri.screensaver 2>/dev/null
  exit 0
}

trap exit_screensaver SIGINT SIGTERM SIGHUP SIGQUIT

printf '\033]11;rgb:00/00/00\007'

tty=$(tty 2>/dev/null)

while true; do
  tte -i ~/.config/omaniri/branding/screensaver.txt \
    --frame-rate 120 --canvas-width 0 --canvas-height 0 --reuse-canvas --anchor-canvas c --anchor-text c\
    --random-effect --no-eol --no-restore-cursor &

  while pgrep -t "${tty#/dev/}" -x tte >/dev/null; do
    if read -n1 -t 1 || ! screensaver_in_focus; then
      exit_screensaver
    fi
  done
done
