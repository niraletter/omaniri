#!/bin/bash

# omaniri:summary=Toggles transparency for the currently focused window.
# omaniri:group=niri

WINDOW_ID=$(niri msg -j focused-window 2>/dev/null | jq -r '
  if .Ok then (.Ok | if type == "object" then . else .[0] end) | .id // empty
  else empty end
')

[[ -n $WINDOW_ID ]] && niri msg action toggle-window-rule-opacity "$WINDOW_ID" >/dev/null 2>&1
