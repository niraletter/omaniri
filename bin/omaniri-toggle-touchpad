#!/bin/bash

# omaniri:summary=Enable, disable, or toggle the touchpad
# omaniri:args=[on|off|toggle]

STATE_CONF="$HOME/.local/state/omaniri/toggles/niri/touchpad-disabled.kdl"

enable() {
  rm -f "$STATE_CONF"
  omaniri-niri-rebuild-toggles
  omaniri-swayosd-client --custom-icon input-touchpad-symbolic --custom-message "Touchpad enabled"
}

disable() {
  mkdir -p "$(dirname "$STATE_CONF")"
  cat >"$STATE_CONF" <<'EOF'
input {
    touchpad {
        off
    }
}
EOF
  omaniri-niri-rebuild-toggles
  omaniri-swayosd-client --custom-icon touchpad-disabled-symbolic --custom-message "Touchpad disabled"
}

case "${1:-toggle}" in
  on) enable ;;
  off) disable ;;
  toggle) if [[ -f $STATE_CONF ]]; then enable; else disable; fi ;;
esac
