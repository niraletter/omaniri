#!/bin/bash

# omaniri:summary=Overwrite the user config for the Limine bootloader and rebuild it.
# omaniri:requires-sudo=true

if [[ -f /boot/EFI/Linux/omaniri_linux.efi ]] && [[ -f /boot/EFI/Linux/$(cat /etc/machine-id)_linux.efi ]]; then
  echo "Cleanup extra UKI"
  sudo rm -f /boot/EFI/Linux/$(cat /etc/machine-id)_linux.efi
fi
echo "Resetting limine config"

sudo mv /boot/limine.conf /boot/limine.conf.bak

sudo cp ~/.local/share/omaniri/default/limine/limine.conf /boot/limine.conf

sudo limine-update
sudo limine-snapper-sync
