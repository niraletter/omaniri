#!/bin/bash

# omaniri:summary=Cycle focused monitor scaling through 1x, 1.25x, 1.6x, 2x, 3x, and 4x
# omaniri:group=niri
# omaniri:args=[--reverse]

MONITOR_INFO=$(niri msg -j focused-output 2>/dev/null | jq -c '
  (if type == "object" and has("Ok") then .Ok else . end | if type == "object" then . else .[0] end)
')
[[ -z $MONITOR_INFO || $MONITOR_INFO == "null" ]] && exit 0

ACTIVE_MONITOR=$(echo "$MONITOR_INFO" | jq -r '.name')
CURRENT_SCALE=$(echo "$MONITOR_INFO" | jq -r '.logical.scale // 1')
WIDTH=$(echo "$MONITOR_INFO" | jq -r '.logical.width // 0')
HEIGHT=$(echo "$MONITOR_INFO" | jq -r '.logical.height // 0')

SCALES=(1 1.25 1.6 2 3 4)

CURRENT_IDX=$(awk -v s="$CURRENT_SCALE" -v list="${SCALES[*]}" 'BEGIN {
  n = split(list, arr, " ")
  best = 0; best_diff = 1e9
  for (i = 1; i <= n; i++) {
    d = s - arr[i]; if (d < 0) d = -d
    if (d < best_diff) { best_diff = d; best = i - 1 }
  }
  print best
}')

if [[ "$1" == "--reverse" ]]; then
  NEW_IDX=$(( (CURRENT_IDX - 1 + ${#SCALES[@]}) % ${#SCALES[@]} ))
else
  NEW_IDX=$(( (CURRENT_IDX + 1) % ${#SCALES[@]} ))
fi

NEW_SCALE=${SCALES[$NEW_IDX]}

TOGGLE_FLAG="$HOME/.local/state/omaniri/toggles/niri/monitor-scale-$ACTIVE_MONITOR.kdl"
mkdir -p "$(dirname "$TOGGLE_FLAG")"
cat >"$TOGGLE_FLAG" <<EOF
output "$ACTIVE_MONITOR" {
    scale $NEW_SCALE
}
EOF

omaniri-niri-rebuild-toggles

MONITOR_CONF="$HOME/.config/niri/monitors.kdl"
if [[ -f $MONITOR_CONF ]]; then
  if grep -q "output \"$ACTIVE_MONITOR\"" "$MONITOR_CONF" 2>/dev/null; then
    sed -i -E "s|^(output \"$ACTIVE_MONITOR\" \\{[^}]*scale )[0-9.]+|\\1$NEW_SCALE|" "$MONITOR_CONF" 2>/dev/null || true
  fi
fi

notify-send -u low "󰍹    Display scaling set to ${NEW_SCALE}x"
