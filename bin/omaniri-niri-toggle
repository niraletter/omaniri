#!/bin/bash

# omaniri:summary=Toggle permanent niri config flags by copying them into a directory that is included from config.kdl.
# omaniri:group=niri
# omaniri:args=[--enabled-notification <text>] [--disabled-notification <text>] <flag-name>

ENABLED_NOTIFICATION=""
DISABLED_NOTIFICATION=""

while [[ $# -gt 1 ]]; do
  case $1 in
    --enabled-notification) ENABLED_NOTIFICATION="$2"; shift 2 ;;
    --disabled-notification) DISABLED_NOTIFICATION="$2"; shift 2 ;;
    *) break ;;
  esac
done

FLAG_NAME="$1"
FLAG="$HOME/.local/state/omaniri/toggles/niri/$FLAG_NAME.kdl"
FLAG_SOURCE="$OMANIRI_PATH/default/niri/toggles/$FLAG_NAME.kdl"

if [[ -f $FLAG ]]; then
  rm "$FLAG"
  [[ -n $DISABLED_NOTIFICATION ]] && notify-send -u low "$DISABLED_NOTIFICATION"
elif [[ -f $FLAG_SOURCE ]]; then
  cp "$FLAG_SOURCE" "$FLAG"
  [[ -n $ENABLED_NOTIFICATION ]] && notify-send -u low "$ENABLED_NOTIFICATION"
else
  echo "Flag not found: $FLAG_NAME"
  exit 1
fi

omaniri-niri-rebuild-toggles
