#!/bin/bash

# omaniri:summary=Prompt for sudo once and keep the credential alive in the background.
# omaniri:requires-sudo=true

sudo -v
while true; do sleep 45; sudo -n -v; done 2>/dev/null &
SUDO_KEEPALIVE_PID=$!

omaniri_sudo_keepalive_stop() {
  if [[ -n ${SUDO_KEEPALIVE_PID:-} ]]; then
    kill "$SUDO_KEEPALIVE_PID" 2>/dev/null || true
    wait "$SUDO_KEEPALIVE_PID" 2>/dev/null || true
    unset SUDO_KEEPALIVE_PID
  fi
}

trap omaniri_sudo_keepalive_stop EXIT
