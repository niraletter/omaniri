#!/bin/bash

# omaniri:summary=Prompt for sudo once and keep the credential alive in the background.
# omaniri:requires-sudo=true

# Skip when running inside the ISO chroot installer (sudo is pre-configured with NOPASSWD)
if [[ -n "${OMANIRI_CHROOT_INSTALL:-}" ]]; then
  return 0
fi

sudo -v
while true; do sudo -n true; sleep 60; done 2>/dev/null &
SUDO_KEEPALIVE_PID=$!
trap "kill $SUDO_KEEPALIVE_PID 2>/dev/null" EXIT
