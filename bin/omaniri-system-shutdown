#!/bin/bash

# omaniri:summary=Shut down after closing application windows
# omaniri:examples=omaniri shutdown | omaniri system shutdown
# omaniri:aliases=omaniri shutdown

omaniri-state clear re*-required

# Schedule the shutdown to happen after closing windows (detached from terminal)
nohup bash -c "sleep 2 && systemctl poweroff --no-wall" >/dev/null 2>&1 &

# Now close all windows
omaniri-niri-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
