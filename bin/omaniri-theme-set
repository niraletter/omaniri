#!/bin/bash

# omaniri:summary=Apply an omaniri theme
# omaniri:args=<theme-name>
# omaniri:examples=omaniri theme list | omaniri theme set "Tokyo Night"

if [[ -z $1 ]]; then
  echo "Usage: omaniri-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/omaniri/current/theme"
NEXT_THEME_PATH="$HOME/.config/omaniri/current/next-theme"
USER_THEMES_PATH="$HOME/.config/omaniri/themes"
OMANIRI_THEMES_PATH="$OMANIRI_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $OMANIRI_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$OMANIRI_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate colors.toml from alacritty.toml if theme is missing colors.toml
if [[ ! -f $NEXT_THEME_PATH/colors.toml && -f $NEXT_THEME_PATH/alacritty.toml ]]; then
  omaniri-theme-colors-from-alacritty "$NEXT_THEME_PATH"
fi

# Generate dynamic configs
omaniri-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" >"$HOME/.config/omaniri/current/theme.name"

# Change background with theme
if [[ $OMANIRI_THEME_SKIP_BACKGROUND != "1" ]]; then
  omaniri-theme-bg-next
fi

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  omaniri-restart-waybar
fi
omaniri-restart-swayosd
omaniri-restart-terminal
omaniri-restart-hyprctl
omaniri-restart-btop
omaniri-restart-opencode
omaniri-restart-mako
omaniri-restart-helix

# Change app-specific themes
omaniri-theme-set-foot
omaniri-theme-set-gnome
omaniri-theme-set-browser
omaniri-theme-set-vscode
omaniri-theme-set-obsidian
omaniri-theme-set-keyboard

# Call hook on theme set
omaniri-hook theme-set "$THEME_NAME" >/dev/null
