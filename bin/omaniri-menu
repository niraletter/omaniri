  *Tailscale*) present_terminal omaniri-install-tailscale ;;
  *NordVPN*) present_terminal omaniri-install-nordvpn ;;
  *ONCE*) present_terminal omaniri-install-once ;;
  *Bitwarden*) install_and_launch "Bitwarden" "bitwarden bitwarden-cli" "bitwarden" ;;
