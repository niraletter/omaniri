  esac
}

show_install_editor_menu() {
  case $(menu "Install" "Ó£ö  VSCode\nÔÖú  Cursor\nÔÖú  Zed\nÔÖú  Sublime Text\nÔÖú  Helix\nÓėę  Vim\nÔÖú  Emacs") in
  *VSCode*) present_terminal omaniri-install-vscode ;;
