show_about() {
  omaniri-launch-about
}

show_system_menu() {
  local options="уұ„„  Screensaver\nпҖЈ  Lock"
  ! omaniri-toggle-enabled suspend-off && options="$options\nу°’І  Suspend"
  omaniri-hibernation-available && options="$options\nу°ӨҒ  Hibernate"
  options="$options\nу°Қғ  Logout\nу°ңү  Restart\nу°җҘ  Shutdown"

  case $(menu "System" "$options") in
  *Screensaver*) omaniri-launch-screensaver force ;;
  *Lock*) omaniri-system-lock ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Logout*) omaniri-system-logout ;;
  *Restart*) omaniri-system-reboot ;;
  *Shutdown*) omaniri-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "у°Җ»  Apps\nу°§‘  Learn\nуұ“һ  Trigger\nоҜҸ  Style\nоҳ•  Setup\nу°үү  Install\nу°ӯҢ  Remove\nпҖЎ  Update\nо©ҙ  About\nпҖ‘  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "LaunchвҖҰ" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *hardware*) show_hardware_menu ;;
  *share*) show_share_menu ;;
  *reminder-set*) show_custom_reminder_input ;;
  *reminder*) show_reminder_menu ;;
  *background*) show_background_menu ;;
  *capture*) show_capture_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/omaniri/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

toggle_existing_menu

if [[ -n $1 ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
