show_install_ai_menu() {
  ollama_pkg=$(
    (omaniri-cmd-present nvidia-smi && echo ollama-cuda) ||
      (omaniri-cmd-present rocminfo && echo ollama-rocm) ||
      echo ollama
  )

  case $(menu "Install" "о°’  Dictation\nуұҡӨ  LM Studio\nуұҡӨ  Ollama\nуұҡӨ  Crush") in
  *Dictation*) present_terminal omaniri-voxtype-install ;;
  *Studio*) install "LM Studio" "lmstudio-bin" ;;
  *Ollama*) install "Ollama" $ollama_pkg ;;
  *Crush*) install "Crush" "crush-bin" ;;
  *) show_install_menu ;;
  esac
}

