#!/bin/bash

# omaniri:summary=Launch the omaniri Menu or takes a parameter to jump straight to a submenu.

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n $preselect ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n $index ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | omaniri-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$prompt‚Ä¶" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.omaniri.terminal "$@"
}

present_terminal() {
  omaniri-launch-floating-terminal-with-presentation $1
}

open_in_editor() {
  notify-send -u low "Editing config file" "$1"
  omaniri-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; omaniri-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; omaniri-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; omaniri-pkg-add $2 && sleep 2 && omaniri-font-set '$3'"
}

install_terminal() {
  present_terminal "omaniri-install-terminal $1"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; omaniri-pkg-aur-add $2"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; omaniri-pkg-aur-add $2 && setsid gtk-launch $3"
}

show_learn_menu() {
  case $(menu "Learn" "ÔĄú  Keybindings\nÔźÖ  omaniri\nůį®≥  Niri\nůį£á  Arch\nÓöģ  Neovim\nůĪÜÉ  Bash") in
  *Keybindings*) omaniri-menu-keybindings ;;
  *omaniri*) omaniri-launch-webapp "https://github.com/niraletter/omaniri" ;;
  *Niri*) omaniri-launch-webapp "https://niri-wm.github.io/niri/" ;;
  *Arch*) omaniri-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) omaniri-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) omaniri-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "ůįĒõ  Reminder\nÔÄį  Capture\nůįßł  Transcode\nÔĒé  Share\nůįĒé  Toggle\nÓĹį  Hardware") in
  *Reminder*) show_reminder_menu ;;
  *Capture*) show_capture_menu ;;
  *Transcode*) omaniri-transcode || back_to show_trigger_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_reminder_menu() {
  case $(menu "Reminder" "ůįĒõ  Set one\nůįĒõ  Show all\nůįĒõ  Clear all") in
  *Set*) show_custom_reminder_input ;;
  *"Show all"*) omaniri-reminder show ;;
  *"Clear all"*) omaniri-reminder clear ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_custom_reminder_input() {
  local minutes
  minutes=$(omaniri-menu-input "Remind in minutes")

  if [[ $minutes =~ ^[0-9]+$ ]] && ((minutes > 0)); then
    show_reminder_message_input "$minutes"
  elif [[ -n $minutes ]]; then
    omaniri-notification-send "ůįĒõ" "Invalid reminder" "Enter the number of minutes" -u critical
    show_custom_reminder_input
  else
    back_to show_reminder_menu
  fi
}

show_reminder_message_input() {
  local minutes="$1"
  local message
  message=$(omaniri-menu-input "Reminder message")

  if [[ -n $message ]]; then
    omaniri-reminder "$minutes" "$message"
  else
    omaniri-reminder "$minutes"
  fi
}

show_capture_menu() {
  case $(menu "Capture" "ÔÄį  Screenshot\nÔÄĹ  Screenrecord\nůįīĎ  Text Extraction\nůįÉČ  Color") in
  *Screenshot*) omaniri-capture-screenshot ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Text*) omaniri-capture-text-extraction ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

show_screenrecord_menu() {
  omaniri-capture-screenrecording --stop-recording && exit 0

  case $(menu "Screenrecord" "\
ůįēß  Portal ¬∑ desktop + microphone + webcam\n\
ůįēß  Portal ¬∑ desktop + microphone\n\
ůįēß  Portal ¬∑ desktop audio\n\
ůįēß  Portal ¬∑ no audio\n\
ÔÄĹ  Slurp ¬∑ desktop + microphone + webcam\n\
ÔÄĹ  Slurp ¬∑ desktop + microphone\n\
ÔÄĹ  Slurp ¬∑ desktop audio\n\
ÔÄĹ  Slurp ¬∑ no audio") in
  *"Portal ¬∑ desktop + microphone + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    omaniri-capture-screenrecording --portal --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *"Portal ¬∑ desktop + microphone") omaniri-capture-screenrecording --portal --with-desktop-audio --with-microphone-audio ;;
  *"Portal ¬∑ desktop audio") omaniri-capture-screenrecording --portal --with-desktop-audio ;;
  *"Portal ¬∑ no audio") omaniri-capture-screenrecording --portal ;;
  *"Slurp ¬∑ desktop + microphone + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    omaniri-capture-screenrecording --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *"Slurp ¬∑ desktop + microphone") omaniri-capture-screenrecording --with-desktop-audio --with-microphone-audio ;;
  *"Slurp ¬∑ desktop audio") omaniri-capture-screenrecording --with-desktop-audio ;;
  *"Slurp ¬∑ no audio") omaniri-capture-screenrecording ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "ÔĀŅ  Clipboard\nÓ©Ľ  File \nÔĄĒ  Folder") in
  *Clipboard*) omaniri-menu-share clipboard ;;
  *File*) terminal bash -c "omaniri-menu-share file" ;;
  *Folder*) terminal bash -c "omaniri-menu-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  local options="ůĪĄĄ  Screensaver\nůįĒé  Nightlight\nůĪęĖ  Idle Lock\nůįāõ  Notifications\nůįćú  Top Bar\nůĪā¨  Workspace Layout\nÓė™  Window Gaps\nÔčź  1-Window Ratio\nůįćĻ  Monitor Scaling\nÔÄļ  Direct Boot\nůįüĶ  Passwordless Sudo"

  case $(menu "Toggle" "$options") in
  *Screensaver*) omaniri-toggle-screensaver ;;
  *Nightlight*) omaniri-toggle-nightlight ;;
  *Idle*) omaniri-toggle-idle ;;
  *Notifications*) omaniri-toggle-notification-silencing ;;
  *Bar*) omaniri-toggle-waybar ;;
  *Layout*) omaniri-niri-workspace-layout-toggle ;;
  *Ratio*) omaniri-niri-window-single-square-aspect-toggle ;;
  *Gaps*) omaniri-niri-window-gaps-toggle ;;
  *Scaling*) omaniri-niri-monitor-scaling-cycle ;;
  *"Direct Boot"*) present_terminal omaniri-config-direct-boot ;;
  *"Passwordless Sudo"*) present_terminal omaniri-sudo-passwordless ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_menu() {
  local options="ůįõß  Laptop Display\n ůįćĻ  Mirror Display"

  if omaniri-hw-hybrid-gpu; then
    options="$options\nÓįô  Hybrid GPU"
  fi

  if omaniri-hw-touchpad; then
    options="$options\nůįüł  Touchpad"
  fi

  if omaniri-hw-dell-xps-haptic-touchpad && omaniri-cmd-present dell-xps-touchpad-haptics; then
    options="$options\nůįĆĆ  Touchpad Haptics"
  fi

  if omaniri-hw-touchscreen; then
    options="$options\nůįÜĹ  Touchscreen"
  fi

  case $(menu "Toggle" "$options") in
  *Laptop*) omaniri-niri-monitor-internal toggle ;;
  *Mirror*) omaniri-niri-monitor-internal-mirror toggle ;;
  *Haptics*) show_hardware_touchpad_haptics_menu ;;
  *Touchpad*) omaniri-toggle-touchpad ;;
  *Touchscreen*) omaniri-toggle-touchscreen ;;
  *"Hybrid GPU"*) present_terminal omaniri-toggle-hybrid-gpu ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_touchpad_haptics_menu() {
  local current=$(dell-xps-touchpad-haptics get)
  local selected=$(menu "Touchpad Haptics" "low\nmid\nhigh" "" "$current")

  if [[ -n $selected ]]; then
    dell-xps-touchpad-haptics set "$selected"
  else
    back_to show_hardware_menu
  fi
}

show_style_menu() {
  case $(menu "Style" "ůįłĆ  Theme\nůįüĶ  Unlock\nÓôô  Font\nÔÄĺ  Background\nůį®≥  Niri\nůĪĄĄ  Screensaver\nÓ©ī  About") in
  *Theme*) show_theme_menu ;;
  *Unlock*) omaniri-launch-walker -m menus:omaniriunlocks --width 800 --minheight 400 ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *Niri*) open_in_editor ~/.config/niri/looknfeel.kdl ;;
  *Screensaver*) show_screensaver_menu ;;
  *About*) show_about_menu ;;
  *) show_main_menu ;;
  esac
}

