  case $(menu "Install" "ůį£á  Package\nůį£á  AUR\nÔČ®  Web App\nÔíČ  TUI\nÔíá  Service\nÓĮŹ  Style\nůįĶģ  Development\nÔÖú  Editor\nÔíČ  Terminal\nÔČ®  Browser\nůĪö§  AI\nÔĄõ  Gaming\nůįć≤  Windows") in
  *Package*) terminal omaniri-pkg-install ;;
  *AUR*) terminal omaniri-pkg-aur-install ;;
