#!/bin/bash

# omaniri:summary=Launch the omaniri Menu or takes a parameter to jump straight to a submenu.

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n $preselect ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n $index ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | omaniri-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptвҖҰ" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.omaniri.terminal "$@"
}

present_terminal() {
  omaniri-launch-floating-terminal-with-presentation $1
}

open_in_editor() {
  notify-send -u low "Editing config file" "$1"
  omaniri-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; omaniri-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; omaniri-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; omaniri-pkg-add $2 && sleep 2 && omaniri-font-set '$3'"
}

install_terminal() {
  present_terminal "omaniri-install-terminal $1"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; omaniri-pkg-aur-add $2"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; omaniri-pkg-aur-add $2 && setsid gtk-launch $3"
}

show_learn_menu() {
  case $(menu "Learn" "п„ң  Keybindings\nпҗ…  omaniri\nу°Ёі  Niri\nу°ЈҮ  Arch\nоҡ®  Neovim\nуұҶғ  Bash") in
  *Keybindings*) omaniri-menu-keybindings ;;
  *omaniri*) omaniri-launch-webapp "https://github.com/niraletter/omaniri" ;;
  *Niri*) omaniri-launch-webapp "https://niri-wm.github.io/niri/" ;;
  *Arch*) omaniri-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) omaniri-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) omaniri-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "у°”ӣ  Reminder\nпҖ°  Capture\nу°§ё  Transcode\nп”Һ  Share\nу°”Һ  Toggle\nоҪ°  Hardware") in
  *Reminder*) show_reminder_menu ;;
  *Capture*) show_capture_menu ;;
  *Transcode*) omaniri-transcode || back_to show_trigger_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *Hardware*) show_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_reminder_menu() {
  case $(menu "Reminder" "у°”ӣ  Set one\nу°”ӣ  Show all\nу°”ӣ  Clear all") in
  *Set*) show_custom_reminder_input ;;
  *"Show all"*) omaniri-reminder show ;;
  *"Clear all"*) omaniri-reminder clear ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_custom_reminder_input() {
  local minutes
  minutes=$(omaniri-menu-input "Remind in minutes")

  if [[ $minutes =~ ^[0-9]+$ ]] && ((minutes > 0)); then
    show_reminder_message_input "$minutes"
  elif [[ -n $minutes ]]; then
    omaniri-notification-send "у°”ӣ" "Invalid reminder" "Enter the number of minutes" -u critical
    show_custom_reminder_input
  else
    back_to show_reminder_menu
  fi
}

show_reminder_message_input() {
  local minutes="$1"
  local message
  message=$(omaniri-menu-input "Reminder message")

  if [[ -n $message ]]; then
    omaniri-reminder "$minutes" "$message"
  else
    omaniri-reminder "$minutes"
  fi
}

show_capture_menu() {
  case $(menu "Capture" "пҖ°  Screenshot\nпҖҪ  Screenrecord\nу°ҙ‘  Text Extraction\nу°ғү  Color") in
  *Screenshot*) omaniri-capture-screenshot ;;
  *Screenrecord*) show_screenrecord_menu ;;
  *Text*) omaniri-capture-text-extraction ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) back_to show_trigger_menu ;;
  esac
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

show_screenrecord_menu() {
  omaniri-capture-screenrecording --stop-recording && exit 0

  case $(menu "Screenrecord" "\
у°•§  Portal В· desktop + microphone + webcam\n\
у°•§  Portal В· desktop + microphone\n\
у°•§  Portal В· desktop audio\n\
у°•§  Portal В· no audio\n\
пҖҪ  Slurp В· desktop + microphone + webcam\n\
пҖҪ  Slurp В· desktop + microphone\n\
пҖҪ  Slurp В· desktop audio\n\
пҖҪ  Slurp В· no audio") in
  *"Portal В· desktop + microphone + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    omaniri-capture-screenrecording --portal --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *"Portal В· desktop + microphone") omaniri-capture-screenrecording --portal --with-desktop-audio --with-microphone-audio ;;
  *"Portal В· desktop audio") omaniri-capture-screenrecording --portal --with-desktop-audio ;;
  *"Portal В· no audio") omaniri-capture-screenrecording --portal ;;
  *"Slurp В· desktop + microphone + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    omaniri-capture-screenrecording --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *"Slurp В· desktop + microphone") omaniri-capture-screenrecording --with-desktop-audio --with-microphone-audio ;;
  *"Slurp В· desktop audio") omaniri-capture-screenrecording --with-desktop-audio ;;
  *"Slurp В· no audio") omaniri-capture-screenrecording ;;
  *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "пҒҝ  Clipboard\nо©»  File \nп„”  Folder") in
  *Clipboard*) omaniri-menu-share clipboard ;;
  *File*) terminal bash -c "omaniri-menu-share file" ;;
  *Folder*) terminal bash -c "omaniri-menu-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  local options="уұ„„  Screensaver\nу°”Һ  Nightlight\nуұ«–  Idle Lock\nу°Ӯӣ  Notifications\nу°Қң  Top Bar\nуұӮ¬  Workspace Layout\nоҳӘ  Window Gaps\nпӢҗ  1-Window Ratio\nу°Қ№  Monitor Scaling\nпҖә  Direct Boot\nу°ҹө  Passwordless Sudo"

  case $(menu "Toggle" "$options") in
  *Screensaver*) omaniri-toggle-screensaver ;;
  *Nightlight*) omaniri-toggle-nightlight ;;
  *Idle*) omaniri-toggle-idle ;;
  *Notifications*) omaniri-toggle-notification-silencing ;;
  *Bar*) omaniri-toggle-waybar ;;
  *Layout*) omaniri-niri-workspace-layout-toggle ;;
  *Ratio*) omaniri-niri-window-single-square-aspect-toggle ;;
  *Gaps*) omaniri-niri-window-gaps-toggle ;;
  *Scaling*) omaniri-niri-monitor-scaling-cycle ;;
  *"Direct Boot"*) present_terminal omaniri-config-direct-boot ;;
  *"Passwordless Sudo"*) present_terminal omaniri-sudo-passwordless ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_menu() {
  local options="у°ӣ§  Laptop Display\n у°Қ№  Mirror Display"

  if omaniri-hw-hybrid-gpu; then
    options="$options\nо°ҷ  Hybrid GPU"
  fi

  if omaniri-hw-touchpad; then
    options="$options\nу°ҹё  Touchpad"
  fi

  if omaniri-hw-dell-xps-haptic-touchpad && omaniri-cmd-present dell-xps-touchpad-haptics; then
    options="$options\nу°ҢҢ  Touchpad Haptics"
  fi

  if omaniri-hw-touchscreen; then
    options="$options\nу°ҶҪ  Touchscreen"
  fi

  case $(menu "Toggle" "$options") in
  *Laptop*) omaniri-niri-monitor-internal toggle ;;
  *Mirror*) omaniri-niri-monitor-internal-mirror toggle ;;
  *Haptics*) show_hardware_touchpad_haptics_menu ;;
  *Touchpad*) omaniri-toggle-touchpad ;;
  *Touchscreen*) omaniri-toggle-touchscreen ;;
  *"Hybrid GPU"*) present_terminal omaniri-toggle-hybrid-gpu ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_hardware_touchpad_haptics_menu() {
  local current=$(dell-xps-touchpad-haptics get)
  local selected=$(menu "Touchpad Haptics" "low\nmid\nhigh" "" "$current")

  if [[ -n $selected ]]; then
    dell-xps-touchpad-haptics set "$selected"
  else
    back_to show_hardware_menu
  fi
}

show_style_menu() {
  case $(menu "Style" "у°ёҢ  Theme\nу°ҹө  Unlock\nоҷҷ  Font\nпҖҫ  Background\nу°Ёі  Niri\nуұ„„  Screensaver\nо©ҙ  About") in
  *Theme*) show_theme_menu ;;
  *Unlock*) omaniri-launch-walker -m menus:omaniriunlocks --width 800 --minheight 400 ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *Niri*) open_in_editor ~/.config/niri/looknfeel.kdl ;;
  *Screensaver*) show_screensaver_menu ;;
  *About*) show_about_menu ;;
  *) show_main_menu ;;
  esac
}

show_about_menu() {
  case $(menu "About" "пҒ„  Edit Text\nпҖҫ  Set From Image\nп‘Ә  Restore Default") in
  *Text*) omaniri-branding-about text ;;
  *Image*) omaniri-branding-about image ;;
  *Default*) omaniri-branding-about reset ;;
  *) show_style_menu ;;
  esac
}

show_screensaver_menu() {
  case $(menu "Screensaver" "пҒ„  Edit Text\nпҖҫ  Set From Image\nп‘Ә  Restore Default") in
  *Text*) omaniri-branding-screensaver text ;;
  *Image*) omaniri-branding-screensaver image ;;
  *Default*) omaniri-branding-screensaver reset ;;
  *) show_style_menu ;;
  esac
}

show_theme_menu() {
  omaniri-launch-walker -m menus:omanirithemes --width 800 --minheight 400
}

show_background_menu() {
  omaniri-launch-walker -m menus:omaniriBackgroundSelector --width 800 --minheight 400
}

show_font_menu() {
  theme=$(menu "Font" "$(omaniri-font-list)" "--width 350" "$(omaniri-font-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_style_menu
  else
    omaniri-font-set "$theme"
  fi
}

show_setup_menu() {
  local options="оҳё  Audio\nпҮ«  Wifi\nу°ӮҜ  Bluetooth\nуұҗӢ  Power Profile\nпҖ‘  System Sleep\nу°Қ№  Monitors"
  [[ -f ~/.config/niri/bindings.kdl ]] && options="$options\nп„ң  Keybindings"
  [[ -f ~/.config/niri/input.kdl ]] && options="$options\nоҫә  Input"
  options="$options\nпҖ…  Defaults\nу°ұ”  DNS\nо¬‘  Security\nоҳ•  Config"

  case $(menu "Setup" "$options") in
  *Audio*) omaniri-launch-audio ;;
  *Wifi*) omaniri-launch-wifi ;;
  *Bluetooth*) omaniri-launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *System*) show_setup_system_menu ;;
  *Monitors*) open_in_editor ~/.config/niri/monitors.kdl ;;
  *Keybindings*) open_in_editor ~/.config/niri/bindings.kdl ;;
  *Input*) open_in_editor ~/.config/niri/input.kdl ;;
  *Defaults*) show_setup_default_menu ;;
  *DNS*) present_terminal omaniri-setup-dns ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  profile=$(menu "Power Profile" "$(omaniri-powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ $profile == "CNCLD" || -z $profile ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_security_menu() {
  case $(menu "Setup" "у°Ҳ·  Fingerprint\nо¬‘  Fido2") in
  *Fingerprint*) present_terminal omaniri-setup-security-fingerprint ;;
  *Fido2*) present_terminal omaniri-setup-security-fido2 ;;
  *) show_setup_menu ;;
  esac
}

show_setup_default_menu() {
  case $(menu "Default" "п’Ҳ  Browser\nп’ү  Terminal\nп…ң  Editor") in
  *Browser*) show_setup_default_browser_menu ;;
  *Terminal*) show_setup_default_terminal_menu ;;
  *Editor*) show_setup_default_editor_menu ;;
  *) show_setup_menu ;;
  esac
}

browser_desktop_exists() {
  [[ -f ~/.local/share/applications/$1 || -f ~/.nix-profile/share/applications/$1 || -f /usr/share/applications/$1 ]]
}

show_setup_default_browser_menu() {
  local options=""
  browser_desktop_exists chromium.desktop && options="$optionsпүЁ  Chromium"
  browser_desktop_exists google-chrome.desktop && options="${options:+$options\n}у°ҠҜ  Chrome"
  browser_desktop_exists brave-browser.desktop && options="${options:+$options\n}у°–ҹ  Brave"
  browser_desktop_exists brave-origin-beta.desktop && options="${options:+$options\n}у°–ҹ  Brave Origin"
  browser_desktop_exists microsoft-edge.desktop && options="${options:+$options\n}у°Ү©  Edge"
  browser_desktop_exists firefox.desktop && options="${options:+$options\n}у°Ҳ№  Firefox"
  browser_desktop_exists zen.desktop && options="${options:+$options\n}у°–ҹ  Zen"

  local current=""
  case "$(omaniri-default-browser)" in
  chromium) current="пүЁ  Chromium" ;;
  chrome) current="у°ҠҜ  Chrome" ;;
  brave) current="у°–ҹ  Brave" ;;
  brave-origin) current="у°–ҹ  Brave Origin" ;;
  edge) current="у°Ү©  Edge" ;;
  firefox) current="у°Ҳ№  Firefox" ;;
  zen) current="у°–ҹ  Zen" ;;
  esac

  case $(menu "Default Browser" "$options" "" "$current") in
  *Chromium*) omaniri-default-browser chromium ;;
  *Chrome*) omaniri-default-browser chrome ;;
  *"Brave Origin"*) omaniri-default-browser brave-origin ;;
  *Brave*) omaniri-default-browser brave ;;
  *Edge*) omaniri-default-browser edge ;;
  *Firefox*) omaniri-default-browser firefox ;;
  *Zen*) omaniri-default-browser zen ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_terminal_menu() {
  local options=""
  omaniri-cmd-present alacritty && options="$optionsоһ•  Alacritty"
  omaniri-cmd-present foot && options="${options:+$options\n}оһ•  Foot"
  omaniri-cmd-present ghostty && options="${options:+$options\n}оһ•  Ghostty"
  omaniri-cmd-present kitty && options="${options:+$options\n}оһ•  Kitty"

  local current=""
  case "$(omaniri-default-terminal)" in
  alacritty) current="оһ•  Alacritty" ;;
  foot) current="оһ•  Foot" ;;
  ghostty) current="оһ•  Ghostty" ;;
  kitty) current="оһ•  Kitty" ;;
  esac

  case $(menu "Default Terminal" "$options" "" "$current") in
  *Alacritty*) omaniri-default-terminal alacritty ;;
  *Foot*) omaniri-default-terminal foot ;;
  *Ghostty*) omaniri-default-terminal ghostty ;;
  *Kitty*) omaniri-default-terminal kitty ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_default_editor_menu() {
  local options=""
  omaniri-cmd-present nvim && options="$optionsоҡ®  Neovim"
  omaniri-cmd-present code && options="${options:+$options\n}оЈҡ  VSCode"
  omaniri-cmd-present cursor && options="${options:+$options\n}п…ң  Cursor"
  omaniri-cmd-present zeditor && options="${options:+$options\n}п…ң  Zed"
  omaniri-cmd-present sublime_text && options="${options:+$options\n}п…ң  Sublime Text"
  omaniri-cmd-present helix && options="${options:+$options\n}п…ң  Helix"
  omaniri-cmd-present vim && options="${options:+$options\n}оҳ«  Vim"
  omaniri-cmd-present emacs && options="${options:+$options\n}п…ң  Emacs"

  local current=""
  case "$(omaniri-default-editor)" in
  nvim) current="оҡ®  Neovim" ;;
  code) current="оЈҡ  VSCode" ;;
  cursor) current="п…ң  Cursor" ;;
  zed | zeditor) current="п…ң  Zed" ;;
  sublime_text) current="п…ң  Sublime Text" ;;
  helix) current="п…ң  Helix" ;;
  vim) current="оҳ«  Vim" ;;
  emacs) current="п…ң  Emacs" ;;
  esac

  case $(menu "Default Editor" "$options" "" "$current") in
  *Neovim*) omaniri-default-editor nvim ;;
  *VSCode*) omaniri-default-editor code ;;
  *Cursor*) omaniri-default-editor cursor ;;
  *Zed*) omaniri-default-editor zed ;;
  *Sublime*) omaniri-default-editor sublime_text ;;
  *Helix*) omaniri-default-editor helix ;;
  *Vim*) omaniri-default-editor vim ;;
  *Emacs*) omaniri-default-editor emacs ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "у°Ёі  Niri\nпҚҷ  Hypridle\nпҚҷ  Hyprlock\nпҚҷ  Hyprsunset\nпҚқ  Swayosd\nу°Ң§  Walker\nу°Қң  Waybar\nу°һ…  XCompose") in
  *Niri*) open_in_editor ~/.config/niri/config.kdl ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && omaniri-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && omaniri-restart-hyprsunset ;;
  *Swayosd*) open_in_editor ~/.config/swayosd/config.toml && omaniri-restart-swayosd ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && omaniri-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && omaniri-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && omaniri-restart-xcompose ;;
  *) show_setup_menu ;;
  esac
}

show_setup_system_menu() {
  local options=""

  if omaniri-toggle-enabled suspend-off; then
    options="$optionsу°’І  Enable Suspend"
  else
    options="$optionsу°’І  Disable Suspend"
  fi

  if omaniri-hibernation-available; then
    options="$options\nу°ӨҒ  Disable Hibernate"
  else
    options="$options\nу°ӨҒ  Enable Hibernate"
  fi

  case $(menu "System" "$options") in
  *Suspend*) omaniri-toggle-suspend ;;
  *"Enable Hibernate"*) present_terminal omaniri-hibernation-setup ;;
  *"Disable Hibernate"*) present_terminal omaniri-hibernation-remove ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "у°ЈҮ  Package\nу°ЈҮ  AUR\nпүЁ  Web App\nп’ү  TUI\nп’Ү  Service\nоҜҸ  Style\nу°ө®  Development\nп…ң  Editor\nп’ү  Terminal\nпүЁ  Browser\nуұҡӨ  AI\nп„ӣ  Gaming\nу°ҚІ  Windows") in
  *Package*) terminal omaniri-pkg-install ;;
  *AUR*) terminal omaniri-pkg-aur-install ;;
  *Web*) present_terminal omaniri-webapp-install ;;
  *TUI*) present_terminal omaniri-tui-install ;;
  *Service*) show_install_service_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *Browser*) show_install_browser_menu ;;
  *Gaming*) show_install_gaming_menu ;;
  *AI*) show_install_ai_menu ;;
  *Windows*) present_terminal "omaniri-windows-vm install" ;;
  *) show_main_menu ;;
  esac
}

show_install_browser_menu() {
  case $(menu "Install" "пүЁ  Chrome\nпүЁ  Edge\nпүЁ  Brave\nпүЁ  Brave Origin\nпү©  Firefox\nу°–ҹ  Zen") in
  *Chrome*) present_terminal "omaniri-install-browser chrome" ;;
  *Edge*) present_terminal "omaniri-install-browser edge" ;;
  *"Brave Origin"*) present_terminal "omaniri-install-browser brave-origin" ;;
  *Brave*) present_terminal "omaniri-install-browser brave" ;;
  *Firefox*) present_terminal "omaniri-install-browser firefox" ;;
  *Zen*) present_terminal "omaniri-install-browser zen" ;;
  *) show_install_menu ;;
  esac
}

show_install_service_menu() {
  case $(menu "Install" "оңҮ  Dropbox\nп’Ү  Tailscale\nуұҮұ  NordVPN [AUR]\nу°Ҹ–  ONCE\nу°ҹө  Bitwarden\nоҹ°  Chromium Account") in
  *Dropbox*) present_terminal omaniri-install-dropbox ;;
  *Tailscale*) present_terminal omaniri-install-tailscale ;;
  *NordVPN*) present_terminal omaniri-install-nordvpn ;;
  *ONCE*) present_terminal omaniri-install-once ;;
  *Bitwarden*) install_and_launch "Bitwarden" "bitwarden bitwarden-cli" "bitwarden" ;;
  *Chromium*) present_terminal omaniri-install-chromium-google-account ;;
  *) show_install_menu ;;
  esac
}

show_install_editor_menu() {
  case $(menu "Install" "оЈҡ  VSCode\nп…ң  Cursor\nп…ң  Zed\nп…ң  Sublime Text\nп…ң  Helix\nоҳ«  Vim\nп…ң  Emacs") in
  *VSCode*) present_terminal omaniri-install-vscode ;;
  *Cursor*) install_and_launch "Cursor" "cursor-bin" "cursor" ;;
  *Zed*) present_terminal omaniri-install-zed ;;
  *Sublime*) install_and_launch "Sublime Text" "sublime-text-4" "sublime_text" ;;
  *Helix*) present_terminal omaniri-install-helix ;;
  *Vim*) install "Vim" "vim" ;;
  *Emacs*) install "Emacs" "emacs-wayland" && systemctl --user enable --now emacs.service ;;
  *) show_install_menu ;;
  esac
}

show_install_terminal_menu() {
