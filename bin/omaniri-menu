  local options=""
  omaniri-cmd-present nvim && options="$optionsÓöģ  Neovim"
  omaniri-cmd-present code && options="${options:+$options\n}Ó£ö  VSCode"
  omaniri-cmd-present cursor && options="${options:+$options\n}ÔÖú  Cursor"
  omaniri-cmd-present zeditor && options="${options:+$options\n}ÔÖú  Zed"
  omaniri-cmd-present sublime_text && options="${options:+$options\n}ÔÖú  Sublime Text"
  omaniri-cmd-present helix && options="${options:+$options\n}ÔÖú  Helix"
  omaniri-cmd-present vim && options="${options:+$options\n}Óėę  Vim"
  omaniri-cmd-present emacs && options="${options:+$options\n}ÔÖú  Emacs"

  local current=""
  case "$(omaniri-default-editor)" in
  nvim) current="Óöģ  Neovim" ;;
  code) current="Ó£ö  VSCode" ;;
  cursor) current="ÔÖú  Cursor" ;;
  zed | zeditor) current="ÔÖú  Zed" ;;
  sublime_text) current="ÔÖú  Sublime Text" ;;
  helix) current="ÔÖú  Helix" ;;
  vim) current="Óėę  Vim" ;;
  emacs) current="ÔÖú  Emacs" ;;
  esac

  case $(menu "Default Editor" "$options" "" "$current") in
  *Neovim*) omaniri-default-editor nvim ;;
  *VSCode*) omaniri-default-editor code ;;
  *Cursor*) omaniri-default-editor cursor ;;
  *Zed*) omaniri-default-editor zed ;;
  *Sublime*) omaniri-default-editor sublime_text ;;
  *Helix*) omaniri-default-editor helix ;;
  *Vim*) omaniri-default-editor vim ;;
  *Emacs*) omaniri-default-editor emacs ;;
  *) show_setup_default_menu ;;
  esac
}

show_setup_config_menu() {
  case $(menu "Setup" "ůį®≥  Niri\nÔćô  Hypridle\nÔćô  Hyprlock\nÔćô  Hyprsunset\nÔćĚ  Swayosd\nůįĆß  Walker\nůįćú  Waybar\nůįěÖ  XCompose") in
  *Niri*) open_in_editor ~/.config/niri/config.kdl ;;
  *Hypridle*) open_in_editor ~/.config/hypr/hypridle.conf && omaniri-restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.config/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.config/hypr/hyprsunset.conf && omaniri-restart-hyprsunset ;;
  *Swayosd*) open_in_editor ~/.config/swayosd/config.toml && omaniri-restart-swayosd ;;
  *Walker*) open_in_editor ~/.config/walker/config.toml && omaniri-restart-walker ;;
  *Waybar*) open_in_editor ~/.config/waybar/config.jsonc && omaniri-restart-waybar ;;
  *XCompose*) open_in_editor ~/.XCompose && omaniri-restart-xcompose ;;
  *) show_setup_menu ;;
  esac
}

show_setup_system_menu() {
  local options=""

  if omaniri-toggle-enabled suspend-off; then
    options="$optionsůįí≤  Enable Suspend"
  else
    options="$optionsůįí≤  Disable Suspend"
  fi

  if omaniri-hibernation-available; then
    options="$options\nůį§Ā  Disable Hibernate"
  else
    options="$options\nůį§Ā  Enable Hibernate"
  fi

  case $(menu "System" "$options") in
  *Suspend*) omaniri-toggle-suspend ;;
  *"Enable Hibernate"*) present_terminal omaniri-hibernation-setup ;;
  *"Disable Hibernate"*) present_terminal omaniri-hibernation-remove ;;
  *) show_setup_menu ;;
  esac
}

