#!/bin/bash

# omaniri:summary=Install packages from official repos or the AUR if they are missing
# omaniri:args=<packages...>
# omaniri:examples=omaniri pkg add jq ripgrep
# omaniri:requires-sudo=true

CHAOTIC_ONLY=(yaru-icon-theme asusctl)

if (($# == 0)); then
  exit 0
fi

# Offline ISO install: every package (official, Chaotic-AUR, and AUR-built) was
# baked into the [offline] repo at build time, so resolve everything through
# pacman and never fall back to the AUR/network.
if pacman-conf --repo-list 2>/dev/null | grep -qx offline; then
  offline_pkgs=()
  for pkg in "$@"; do
    pacman -Q "$pkg" &>/dev/null && continue
    offline_pkgs+=("$pkg")
  done

  if ((${#offline_pkgs[@]} > 0)); then
    sudo pacman -S --noconfirm --needed "${offline_pkgs[@]}" || exit 1
  fi

  for pkg in "$@"; do
    if ! pacman -Q "$pkg" &>/dev/null; then
      echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
      exit 1
    fi
  done

  exit 0
fi

sudo cp /etc/pacman.conf /etc/pacman.conf.omaniri-bak
trap 'sudo cp /etc/pacman.conf.omaniri-bak /etc/pacman.conf' EXIT

chaotic_off() { sudo sed -i '/^\[chaotic-aur\]/,/^Include/d' /etc/pacman.conf; }

pacman_pkgs=()
aur_pkgs=()

for pkg in "$@"; do
  if pacman -Q "$pkg" &>/dev/null; then
    continue
  fi

  is_whitelisted=false
  for w in "${CHAOTIC_ONLY[@]}"; do
    [[ "$pkg" == "$w" ]] && is_whitelisted=true && break
  done

  output=$(pacman -Si "$pkg" 2>/dev/null)

  if $is_whitelisted; then
    if [[ -z "$output" ]]; then
      echo -e "\033[31mError: $pkg not found in any repo\033[0m" >&2
      exit 1
    fi
    repo=$(echo "$output" | sed -n 's/^Repository\s*:\s*//p')
    if [[ "$repo" != "chaotic-aur" ]]; then
      echo -e "\033[31mError: $pkg must be in Chaotic-AUR, found in $repo\033[0m" >&2
      exit 1
    fi
    pacman_pkgs+=("$pkg")
  else
    if [[ -z "$output" ]]; then
      aur_pkgs+=("$pkg")
    else
      repo=$(echo "$output" | sed -n 's/^Repository\s*:\s*//p')
      if [[ "$repo" == "chaotic-aur" ]]; then
        aur_pkgs+=("$pkg")
      else
        pacman_pkgs+=("$pkg")
      fi
    fi
  fi
done

if ((${#pacman_pkgs[@]} > 0)); then
  sudo pacman -S --noconfirm --needed "${pacman_pkgs[@]}" || exit 1
fi

chaotic_off
if ((${#aur_pkgs[@]} > 0)); then
  yay -S --noconfirm --needed "${aur_pkgs[@]}" || exit 1
fi

for pkg in "$@"; do
  if ! pacman -Q "$pkg" &>/dev/null; then
    echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
    exit 1
  fi
done

exit 0
