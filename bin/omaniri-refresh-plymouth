#!/bin/bash

# omaniri:summary=Overwrite the user config for the Plymouth drive decryption and boot sequence with the omaniri default and rebuild it.
# omaniri:requires-sudo=true

sudo cp -r ~/.local/share/omaniri/default/plymouth/* /usr/share/plymouth/themes/omaniri/
sudo plymouth-set-default-theme omaniri

if command -v limine-mkinitcpio &>/dev/null; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi
