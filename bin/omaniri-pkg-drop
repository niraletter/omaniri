#!/bin/bash

# omaniri:summary=Remove all the named packages from the system if they're installed (otherwise ignore).
# omaniri:args=<packages...>
# omaniri:requires-sudo=true

installed=()
for pkg in "$@"; do
  if pacman -Qq | grep -Fxq "$pkg"; then
    installed+=("$pkg")
  fi
done

if (( ${#installed[@]} > 0 )); then
  sudo pacman -Rns --noconfirm "${installed[@]}"
fi
