#!/bin/bash

# omaniri:summary=Prompt for text input with Walker
# omaniri:group=menu
# omaniri:name=input
# omaniri:args=prompt [walker args...]
# omaniri:examples=omaniri menu input Reminder|omaniri-menu-input "Reminder in minutes" --width 400

set -euo pipefail

prompt="${1:-Input}"
if (( $# > 0 )); then
  shift
fi

omaniri-launch-walker --dmenu --inputonly --width 295 --minheight 1 --maxheight 1 -p "$prompt…" "$@" 2>/dev/null
