#!/bin/bash

# omaniri:summary=Launch or focus on a given web app identified by the window-pattern.
# omaniri:args=<window-pattern> <url-and-flags...>

if (($# == 0)); then
  echo "Usage: omaniri-launch-or-focus-webapp [window-pattern] [url-and-flags...]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift
LAUNCH_COMMAND="omaniri-launch-webapp $@"

exec omaniri-launch-or-focus "$WINDOW_PATTERN" "$LAUNCH_COMMAND"
