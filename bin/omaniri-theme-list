#!/bin/bash

# omaniri:summary=List available themes
# omaniri:examples=omaniri theme list | omaniri theme set "Tokyo Night"

{
  find ~/.config/omaniri/themes/ -mindepth 1 -maxdepth 1 \( -type d -o -type l \) -printf '%f\n'
  find "$OMANIRI_PATH/themes/" -mindepth 1 -maxdepth 1 -type d -printf '%f\n'
} | sort -u | while read -r name; do
  echo "$name" | sed -E 's/(^|-)([a-z])/\1\u\2/g; s/-/ /g'
done
