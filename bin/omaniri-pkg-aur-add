#!/bin/bash

# omaniri:summary=Add the named packages to the system from the AUR if they're missing. Returns false if it couldn't be done.
# omaniri:args=<packages...>

if omaniri-pkg-missing "$@"; then
  pacman_pkgs=()
  aur_pkgs=()
  for pkg in "$@"; do
    if pacman -Si "$pkg" &>/dev/null; then
      pacman_pkgs+=("$pkg")
    else
      aur_pkgs+=("$pkg")
    fi
  done
  if ((${#pacman_pkgs[@]} > 0)); then
    sudo pacman -S --noconfirm --needed "${pacman_pkgs[@]}" || exit 1
  fi
  if ((${#aur_pkgs[@]} > 0)); then
    if [[ -n ${OMANIRI_ONLINE_INSTALL:-} ]]; then
      yay -S --noconfirm --needed "${aur_pkgs[@]}" || exit 1
    else
      echo "The following packages are not available in the offline mirror: ${aur_pkgs[*]}" >&2
      exit 1
    fi
  fi
fi

for pkg in "$@"; do
  # Secondary check to handle states where pacman doesn't actually register an error
  if ! pacman -Q "$pkg" &>/dev/null; then
    echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
    exit 1
  fi
done

exit 0
