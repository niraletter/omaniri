#!/bin/bash

# omaniri:summary=Restore the default omaniri Plymouth boot theme and SDDM login screen
# omaniri:requires-sudo=true

theme_dir="/usr/share/plymouth/themes/omaniri"

sudo find ~/.local/share/omaniri/default/plymouth -maxdepth 1 -type f -exec cp -t "$theme_dir/" {} +
sudo plymouth-set-default-theme omaniri

if omaniri-cmd-present limine-mkinitcpio; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi

omaniri-refresh-sddm
