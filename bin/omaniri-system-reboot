#!/bin/bash

# omaniri:summary=Reboot after closing application windows
# omaniri:examples=omaniri reboot | omaniri system reboot
# omaniri:aliases=omaniri reboot

omaniri-state clear re*-required

# Schedule the reboot to happen after closing windows (detached from terminal)
nohup bash -c "sleep 2 && systemctl reboot --no-wall" >/dev/null 2>&1 &

# Now close all windows
omaniri-niri-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
