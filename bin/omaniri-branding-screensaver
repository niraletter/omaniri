#!/bin/bash

# omaniri:summary=Edit, set, or reset screensaver branding
# omaniri:group=branding
# omaniri:name=screensaver
# omaniri:args=<image|text|reset>
# omaniri:examples=omaniri branding screensaver image | omaniri branding screensaver text | omaniri branding screensaver reset

set -euo pipefail

case "${1:-}" in
image)
  image=$(omaniri-menu-file "Logo image" "$HOME" "svg png")
  if [[ -n $image ]] && omaniri-transcode-ascii "$image" ~/.config/omaniri/branding/screensaver.txt; then
    omaniri-launch-screensaver force >/dev/null 2>&1
  fi
  ;;
text)
  omaniri-launch-editor ~/.config/omaniri/branding/screensaver.txt >/dev/null 2>&1 && omaniri-launch-screensaver force >/dev/null 2>&1
  ;;
reset)
  cp "$OMANIRI_PATH/logo.txt" ~/.config/omaniri/branding/screensaver.txt && omaniri-launch-screensaver force >/dev/null 2>&1
  ;;
*)
  echo "Usage: omaniri-branding-screensaver <image|text|reset>" >&2
  exit 1
  ;;
esac
