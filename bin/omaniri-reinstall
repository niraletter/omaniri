#!/bin/bash

# omaniri:summary=Reinstall omaniri packages and reset default configs
# omaniri:requires-sudo=true

set -e

# Attempt to reinstall all default omaniri packages and reset all the default configs.

echo -e "This will reinstall all the default omaniri packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  omaniri-reinstall-git
  omaniri-reinstall-pkgs
  omaniri-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && omaniri-system-reboot
fi
