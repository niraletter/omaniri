#!/bin/bash

# omaniri:summary=Show Waybar update icon when a new CachyOS release is on the blog
# omaniri:args=[--ack]

CACHYOS_RSS_URL="https://cachyos.org/rss.xml"
CACHYOS_BLOG_URL="https://cachyos.org/blog"
STATE_DIR="${HOME}/.local/state/omaniri"
STATE_FILE="${STATE_DIR}/cachyos-release-seen"
RSS_CACHE="${STATE_DIR}/cachyos-release-rss.xml"
RSS_CACHE_MAX_AGE=21600

fetch_cachyos_rss() {
  mkdir -p "$STATE_DIR"

  if [[ -f $RSS_CACHE ]]; then
    local cache_age=$(( $(date +%s) - $(stat -c %Y "$RSS_CACHE") ))
    if (( cache_age < RSS_CACHE_MAX_AGE )); then
      cat "$RSS_CACHE"
      return 0
    fi
  fi

  if ! curl -fsSL --max-time 20 "$CACHYOS_RSS_URL" -o "${RSS_CACHE}.tmp"; then
    return 1
  fi

  mv "${RSS_CACHE}.tmp" "$RSS_CACHE"
  cat "$RSS_CACHE"
}

latest_cachyos_release() {
  local rss_file="$1"
  local url title

  if command -v xmlstarlet &>/dev/null; then
    url=$(xmlstarlet sel -t -v '(//item[contains(link,"-release")])[1]/link' -n "$rss_file" 2>/dev/null)
    title=$(xmlstarlet sel -t -v '(//item[contains(link,"-release")])[1]/title' -n "$rss_file" 2>/dev/null)
  else
    url=$(grep -oE 'https://cachyos.org/blog/[0-9]+[^<"]*-release/?' "$rss_file" | head -n1)
    title=$(grep -oE '<title>CachyOS [^<]*Release</title>' "$rss_file" | head -n1 | sed 's/<\/?title>//g')
  fi

  url=${url%/}
  if [[ -z $url ]]; then
    return 1
  fi

  printf '%s\n%s\n' "$url" "${title:-CachyOS release}"
}

mark_release_seen() {
  local url="$1"
  printf '%s\n' "$url" >"$STATE_FILE"
}

if [[ ${1:-} == --ack ]]; then
  fetch_cachyos_rss >/dev/null || exit 1
  read -r release_url _ < <(latest_cachyos_release "$RSS_CACHE") || exit 1
  mark_release_seen "$release_url"
  exit 1
fi

fetch_cachyos_rss >/dev/null || exit 1
read -r release_url release_title < <(latest_cachyos_release "$RSS_CACHE") || exit 1

if [[ ! -f $STATE_FILE ]]; then
  mark_release_seen "$release_url"
  exit 1
fi

seen_url=$(<"$STATE_FILE")
if [[ $seen_url == "$release_url" ]]; then
  exit 1
fi

echo "CachyOS release: $release_title"
echo "$CACHYOS_BLOG_URL"
exit 0
