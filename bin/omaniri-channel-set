#!/bin/bash

# omaniri:summary=Set the omaniri channel, which dictates what git branch and package repository is used.
# omaniri:args=<stable|rc|edge|dev>
# omaniri:requires-sudo=true

if (($# == 0)); then
  echo "Usage: omaniri-channel-set [stable|rc|edge|dev]"
  exit 1
else
  channel="$1"
fi

case "$channel" in
"stable") omaniri-branch-set "master" && omaniri-refresh-pacman "stable" ;;
"rc") omaniri-branch-set "rc" && omaniri-refresh-pacman "rc" ;;
"edge") omaniri-branch-set "master" && omaniri-refresh-pacman "edge" ;;
"dev") omaniri-branch-set "dev" && omaniri-refresh-pacman "edge" ;;
*) echo "Unknown channel: $channel"; exit 1; ;;
esac

omaniri-update -y
