#!/bin/bash

# omaniri:summary=Print the current working directory of the active terminal window
# omaniri:hidden=true

terminal_pid=$(niri msg -j focused-window 2>/dev/null | jq -r '
  (if type == "object" and has("Ok") then .Ok else . end | if type == "object" then . else .[0] end) | .pid // empty
  else empty end
')
shell_pid=$(pgrep -P "$terminal_pid" 2>/dev/null | tail -n1)

if [[ -n $shell_pid ]]; then
  cwd=$(readlink -f "/proc/$shell_pid/cwd" 2>/dev/null)
  shell=$(readlink -f "/proc/$shell_pid/exe" 2>/dev/null)

  if grep -qs "$shell" /etc/shells && [[ -d $cwd ]]; then
    echo "$cwd"
  else
    echo "$HOME"
  fi
else
  echo "$HOME"
fi
