#!/bin/bash

# omaniri:summary=Clear the internal-monitor-disable toggle if no external display is connected.

TOGGLE="$HOME/.local/state/omaniri/toggles/niri/internal-monitor-disable.kdl"

if [[ -f $TOGGLE ]] && ! omaniri-hw-external-monitors; then
  rm -f "$TOGGLE"
  omaniri-niri-rebuild-toggles
fi
