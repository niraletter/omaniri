#!/bin/bash

# omaniri:summary=Install Steam and graphics drivers selected for this system
# omaniri:requires-sudo=true

set -e

echo "Installing Steam..."
omaniri-pkg-add steam
omaniri-install-gaming-gpu-lib32

echo ""
echo "Steam will start automatically now. This might take a while..."

setsid gtk-launch steam >/dev/null 2>&1 &
